{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Teak",
  "scopeName": "source.teak",
  "fileTypes": ["tk"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-decl" },
    { "include": "#data-class-decl" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.teak",
          "match": "//.*$"
        },
        {
          "name": "comment.block.teak",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.teak" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.teak" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.teak",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": []
        },
        {
          "name": "string.quoted.double.teak",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "variable.other.interpolated.teak",
              "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
            },
            {
              "name": "meta.embedded.expression.teak",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.teak" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.teak" } },
              "patterns": [{ "include": "$self" }]
            },
            {
              "name": "constant.character.escape.teak",
              "match": "\\\\[ntr\\\\\"']"
            }
          ]
        },
        {
          "name": "string.quoted.single.teak",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.teak",
              "match": "\\\\[ntr\\\\\"']"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.teak",
          "match": "\\b(if|else|when|for|in|while|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.teak",
          "match": "\\b(val|var|fun|data|class)\\b"
        },
        {
          "name": "keyword.other.teak",
          "match": "\\b(to)\\b"
        }
      ]
    },
    "storage": {
      "name": "storage.type.teak",
      "match": "\\b(val|var)\\b"
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.teak",
          "match": "\\b(println|listOf|mutableListOf|setOf|mutableSetOf|mapOf|mutableMapOf|isList|isSet|isMap|Pair|treeMap|treeMapOf|numCmp|strCmp|sha256|jsonParse|jsonStringify|base64Encode|base64Decode|now|sleep|formatTime|abs|floor|ceil|round|sqrt|pow|log|max|min|random|toInt|PI|File|exec|spawn|env|setEnv|httpGet|httpPost|download|HttpServer|go|chan|waitGroup|importNpm|include|requireFile|ArrayList|Sequence|walkDirectory)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.teak",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.teak",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "operators": {
      "name": "keyword.operator.teak",
      "match": "(==|!=|<=|>=|&&|\\|\\||\\.\\.|-\\>|\\+=|-=|\\*=|/=|[+\\-*/%=<>!&|])"
    },
    "function-decl": {
      "patterns": [
        {
          "name": "meta.function.teak",
          "match": "\\bfun\\b\\s*(?:\\(([a-zA-Z_][a-zA-Z0-9_]*)\\s+([A-Z][a-zA-Z0-9_]*)\\)\\s*)?([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "variable.parameter.receiver.teak" },
            "2": { "name": "entity.name.type.teak" },
            "3": { "name": "entity.name.function.teak" }
          }
        }
      ]
    },
    "data-class-decl": {
      "patterns": [
        {
          "name": "meta.class.teak",
          "match": "\\bdata\\s+class\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.class.teak" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.teak",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.teak",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
